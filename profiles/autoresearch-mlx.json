{
  "meta": {
    "name": "autoresearch-mlx",
    "version": "1.0.0",
    "description": "nono profile for trevin-creator/autoresearch-mlx on Apple Silicon (macOS)",
    "author": "Kexin-xu-01"
  },
  "security": {
    "groups": ["deny_credentials", "python_runtime", "system_read_macos", "system_write_macos"]
  },
  "filesystem": {
    "allow": ["$HOME/.cache/autoresearch"],
    "read": ["$HOME/.cache/uv", "$HOME/.local/share/uv"]
  },
  "network": {
    "block": false,
    "network_profile": "developer",
    "allow_domain": ["huggingface.co", "cdn-lfs.huggingface.co"]
  },
  "workdir": {
    "access": "readwrite"
  }
}
