{
  "meta": { "name": "claude-code-autoresearch", "version": "1.0.0", "description": "Claude Code + GPU for autoresearch" },
  "extends": "claude-code",
  "allow_gpu": true,
  "filesystem": {
    "allow": ["$HOME/.cache/autoresearch", "$HOME/.cache/torch", "$HOME/.cache/uv", "$HOME/.local/share/uv", "$HOME/.nv", "/tmp", "/dev/shm"],
    "read": ["$HOME/shared-libs", "$HOME/.nvm", "/proc"]
  }
}
